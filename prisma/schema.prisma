generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Model User (Role diubah dari enum menjadi String)
model User {
  id        String       @id @default(cuid())
  name      String?
  email     String?      @unique
  password  String?      // <-- TAMBAHKAN BARIS INI
  avatarUrl String?
  bannerUrl String?
  bio       String?
  socials   SocialLink[]
  profile   Profile?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String // Misal: "GitHub", "Twitter", "Instagram"
  url       String // Misal: "https://github.com"
  createdAt DateTime @default(now())
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String         @id @default(uuid())
  title       String
  description String                            // ✅ Cukup String biasa
  price       Float                             // ✅ Gunakan Float untuk angka/harga
  badge       String?
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Model SEOSetting (Hapus @db.Text)
model SEOSetting {
  id          String   @id @default("default")
  metaTitle   String
  metaKeyword String
  metaDesc    String
  updatedAt   DateTime @updatedAt
}
